{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run MCP Server",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/server.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Run db.py (connection test)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/db.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    ]
}